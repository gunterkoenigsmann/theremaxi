# permission allowlist) and stays tracked.
/.bash_profile
/.bashrc
/.profile
/.zprofile
/.zshrc
/.gitconfig
/.gitmodules
/.ripgreprc
/.mcp.json
/.idea
/.vscode
/.claude/*
!/.claude/settings.json
