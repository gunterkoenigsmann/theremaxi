# Processed by CMake into the build tree. Build the docs with:
#   cmake --build build --target docs
# Output lands in <build>/docs/html.

PROJECT_NAME           = "ThereMaxi protocol library"
PROJECT_NUMBER         = @PROJECT_VERSION@
PROJECT_BRIEF          = "Parameter, preset and wire format of the Moog Theremini"

INPUT                  = @CMAKE_CURRENT_SOURCE_DIR@/src/protocol/include \
                         @CMAKE_CURRENT_SOURCE_DIR@/DESIGN.md
FILE_PATTERNS          = *.h
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = @CMAKE_CURRENT_SOURCE_DIR@/DESIGN.md

OUTPUT_DIRECTORY       = @DOXYGEN_OUTPUT_DIR@
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
QUIET                  = YES
# The public interface is documented in full, members included, so an
# undocumented one is a genuine omission and fails the build - as does a @param
# naming an argument that does not exist, or a broken reference.
WARN_IF_UNDOCUMENTED   = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS

OPTIMIZE_OUTPUT_FOR_C  = YES
JAVADOC_AUTOBRIEF      = YES
TYPEDEF_HIDES_STRUCT   = YES

# No Graphviz diagrams: they add a dependency on dot without earning their place
# for a single header, and older doxygen tries to run dot regardless of whether
# it is installed.
HAVE_DOT               = NO
